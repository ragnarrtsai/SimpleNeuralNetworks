# Default: track source. Only the things below stay local.

# --- Python ---
.venv/
venv/
**/__pycache__/
**/.pytest_cache/
*.pyc
*.egg-info/

# --- OS / editor ---
.DS_Store

# --- Claude Code local settings ---
.claude/

# --- Logs ---
*.log

# --- Datasets (large; fetched/generated locally) ---
mnist-mlp/input/
youbike-transformer/input/

# --- Training outputs / per-run dirs ---
**/output/

# --- Model checkpoints: ignore the bulk, ship only a curated few ---
chess/checkpoints/*
!chess/checkpoints/best.pt
!chess/checkpoints/weak.pt
!chess/checkpoints/best_iter50.pt
!chess/checkpoints/iter_120.pt

mnist-mlp/model/*
!mnist-mlp/model/20260509_115652.pt

youbike-transformer/model/

# --- youbike-transformer: 程式尚未完成，暫不發布原始碼 ---
# （仍發布它的 README / OVERVIEW / assets）
youbike-transformer/*.py
youbike-transformer/*.ipynb
youbike-transformer/*.csv
youbike-transformer/*.html
